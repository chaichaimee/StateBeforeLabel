#: __init__.py:66
msgid "Announce &Read-only state for Edit boxes"
msgstr "எடிட் பாக்ஸ்களுக்கான ரீட்-ஒன்லி நிலையை அறிவிக்கவும்"

#: __init__.py:56
msgid "Announce &Selected state for Tabs and List items"
msgstr "டேப்கள் மற்றும் லிஸ்ட் உருப்படிகளுக்கான தேர்ந்தெடுக்கப்பட்ட நிலையை அறிவிக்கவும்"

#: __init__.py:51
msgid "Announce &Unavailable state before name (global)"
msgstr "பெயருக்கு முன் Unavailable நிலையை அறிவிக்கவும் (உலகளாவியது)"

#: __init__.py:36
msgid "Enable for Checkboxes, Radio buttons, and Check Menu Items"
msgstr "செக்பாக்ஸ்கள், ரேடியோ பட்டன்கள் மற்றும் செக் மெனு உருப்படிகளுக்குச் செயல்படுத்தவும்"

#: __init__.py:41
msgid "Enable for Toggle buttons"
msgstr "டொகிள் பட்டன்களுக்குச் செயல்படுத்தவும்"

#: __init__.py:46
msgid "Enable for TreeView items (Expanded/Collapsed)"
msgstr "ட்ரீவியூ உருப்படிகளுக்குச் செயல்படுத்தவும் (விரிவாக்கப்பட்டது/சுருக்கப்பட்டது)"

#: __init__.py:61
msgid "Include &Buttons for Expanded/Collapsed detection"
msgstr "விரிவாக்கப்பட்ட/சுருக்கப்பட்ட நிலையைக் கண்டறிய பட்டன்களைச் சேர்க்கவும்"

#: __init__.py:30
msgid "State Before Label"
msgstr "லேபிளுக்கு முன் நிலை"