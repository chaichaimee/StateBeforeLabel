#: __init__.py:66
msgid "Announce &Read-only state for Edit boxes"
msgstr "ປະກາດສະຖານະ &Read-only ສຳລັບກ່ອງແກ້ໄຂ"

#: __init__.py:56
msgid "Announce &Selected state for Tabs and List items"
msgstr "ປະກາດສະຖານະ &Selected ສຳລັບແຖບ ແລະ ລາຍການ"

#: __init__.py:51
msgid "Announce &Unavailable state before name (global)"
msgstr "ປະກາດສະຖານະ &Unavailable ກ່ອນຊື່ (ທົ່ວໄປ)"

#: __init__.py:36
msgid "Enable for Checkboxes, Radio buttons, and Check Menu Items"
msgstr "ເປີດໃຊ້ສຳລັບ Checkboxes, Radio buttons, ແລະ Check Menu Items"

#: __init__.py:41
msgid "Enable for Toggle buttons"
msgstr "ເປີດໃຊ້ສຳລັບ Toggle buttons"

#: __init__.py:46
msgid "Enable for TreeView items (Expanded/Collapsed)"
msgstr "ເປີດໃຊ້ສຳລັບລາຍການ TreeView (ຂະຫຍາຍ/ຫຍໍ້)"

#: __init__.py:61
msgid "Include &Buttons for Expanded/Collapsed detection"
msgstr "ລວມ &Buttons ສຳລັບການກວດຫາການຂະຫຍາຍ/ຫຍໍ້"

#: __init__.py:30
msgid "State Before Label"
msgstr "ສະຖານະກ່ອນປ້າຍຊື່"