#: __init__.py:66
msgid "Announce &Read-only state for Edit boxes"
msgstr "Съобщавай състоянието „само за четене“ при полета за редактиране"

#: __init__.py:56
msgid "Announce &Selected state for Tabs and List items"
msgstr "Съобщавай състоянието „избрано“ за раздели и елементи от списъци"

#: __init__.py:51
msgid "Announce &Unavailable state before name (global)"
msgstr "Съобщавай състоянието „недостъпно“ преди името (глобално)"

#: __init__.py:36
msgid "Enable for Checkboxes, Radio buttons, and Check Menu Items"
msgstr "Активирай за квадратчета за отметка, радио бутони и отметки в менюта"

#: __init__.py:41
msgid "Enable for Toggle buttons"
msgstr "Активирай за превключващи бутони"

#: __init__.py:46
msgid "Enable for TreeView items (Expanded/Collapsed)"
msgstr "Активирай за елементи от дървовидни изгледи (разгърнати/свити)"

#: __init__.py:61
msgid "Include &Buttons for Expanded/Collapsed detection"
msgstr "Включи бутони при откриване на разгърнато/свито състояние"

#: __init__.py:30
msgid "State Before Label"
msgstr "Състояние преди етикета"