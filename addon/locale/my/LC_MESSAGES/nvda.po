#: __init__.py:66
msgid "Announce &Read-only state for Edit boxes"
msgstr "Edit box များအတွက် Read-only အခြေအနေကို ကြေညာရန်"

#: __init__.py:56
msgid "Announce &Selected state for Tabs and List items"
msgstr "Tabs နှင့် List items များအတွက် Selected အခြေအနေကို ကြေညာရန်"

#: __init__.py:51
msgid "Announce &Unavailable state before name (global)"
msgstr "အမည်မတိုင်မီ Unavailable အခြေအနေကို ကြေညာရန် (Global)"

#: __init__.py:36
msgid "Enable for Checkboxes, Radio buttons, and Check Menu Items"
msgstr "Checkboxes, Radio buttons နှင့် Check Menu Items များအတွက် ဖွင့်ရန်"

#: __init__.py:41
msgid "Enable for Toggle buttons"
msgstr "Toggle buttons များအတွက် ဖွင့်ရန်"

#: __init__.py:46
msgid "Enable for TreeView items (Expanded/Collapsed)"
msgstr "TreeView items များအတွက် ဖွင့်ရန် (Expanded/Collapsed)"

#: __init__.py:61
msgid "Include &Buttons for Expanded/Collapsed detection"
msgstr "Expanded/Collapsed ကို သိရှိနိုင်ရန် Buttons များကို ထည့်သွင်းရန်"

#: __init__.py:30
msgid "State Before Label"
msgstr "Label မတိုင်မီ အခြေအနေ"