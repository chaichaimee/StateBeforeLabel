#: __init__.py:66
msgid "Announce &Read-only state for Edit boxes"
msgstr "ایڈٹ بکس کے لیے صرف پڑھنے کے قابل (read-only) حالت کا اعلان کریں"

#: __init__.py:56
msgid "Announce &Selected state for Tabs and List items"
msgstr "ٹیب اور لسٹ آئٹمز کے لیے منتخب شدہ حالت کا اعلان کریں"

#: __init__.py:51
msgid "Announce &Unavailable state before name (global)"
msgstr "نام سے پہلے ناقابل رسائی (unavailable) حالت کا اعلان کریں (عالمی)"

#: __init__.py:36
msgid "Enable for Checkboxes, Radio buttons, and Check Menu Items"
msgstr "چیک باکس، ریڈیو بٹن اور چیک مینو آئٹمز کے لیے فعال کریں"

#: __init__.py:41
msgid "Enable for Toggle buttons"
msgstr "ٹوگل بٹن کے لیے فعال کریں"

#: __init__.py:46
msgid "Enable for TreeView items (Expanded/Collapsed)"
msgstr "ٹری ویو آئٹمز کے لیے فعال کریں (پھیلا ہوا/سمٹا ہوا)"

#: __init__.py:61
msgid "Include &Buttons for Expanded/Collapsed detection"
msgstr "پھیلے ہوئے/سمٹے ہوئے کی شناخت کے لیے بٹن شامل کریں"

#: __init__.py:30
msgid "State Before Label"
msgstr "لیبل سے پہلے حالت"